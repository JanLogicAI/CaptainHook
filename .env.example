# Jira Configuration (all three are required)
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=your_jira_api_token_here
# Must be your real Jira Cloud host, e.g. https://acme.atlassian.net
# The placeholder value below is rejected by Config.validate() on purpose.
JIRA_BASE_URL=https://your-domain.atlassian.net

# Discord Configuration (optional but really useful- for interactive planning)
DISCORD_WEBHOOK_URL=
DISCORD_CHANNEL_ID=
DISCORD_BOT_TOKEN=

# Codebase Analysis (optional but essential, without always fallback generic plan - for codebase-aware plans)
# Absolute path to the Claude Code CLI binary. `~` is expanded.
# If empty, the agent falls back to `claude` on PATH; if that's missing, codebase analysis is skipped.
# Example: CLAUDE_CLI_PATH=~/.local/bin/claude
CLAUDE_CLI_PATH=

# Polling Configuration
POLL_INTERVAL_SECONDS=300
